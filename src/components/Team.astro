---
const team = [
  { name: "Alex Robertson", role: "Founder - CEO", img: "https://images.unsplash.com/photo-1560250097-0b93528c31e0?q=80&w=400" },
  { name: "Ayesha Khanam", role: "Problem Solver", img: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=400" },
  { name: "Shakib Al Hasan", role: "Problem Solver", img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=400" },
  { name: "Sofia Hernandez", role: "Problem Solver", img: "https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=400" }
];
---

<section class="py-20 px-6 bg-[#0a1b1b]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 py-1 px-4 rounded-full bg-[#142e2e] text-lime-400 text-sm border border-[#1f4646] mb-4">
        Nuestro Equipo
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white">Conoce a nuestro equipo de expertos</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member) => (
        <div class="team-card group relative overflow-hidden rounded-3xl">
          <!-- Imagen -->
          <img src={member.img} alt={member.name} class="w-full h-[400px] object-cover transition-transform duration-500 group-hover:scale-110" />
          
          <!-- Capa de overlay social (solo en Alex Robertson por ahora) -->
          {member.name === "Alex Robertson" && (
            <div class="absolute bottom-20 left-4 right-4 bg-white/10 backdrop-blur-md p-4 rounded-2xl flex justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <a href="#" class="text-white hover:text-lime-400">X</a>
              <a href="#" class="text-white hover:text-lime-400">in</a>
              <a href="#" class="text-white hover:text-lime-400">IG</a>
            </div>
          )}

          <!-- Info -->
          <div class="mt-6 text-center">
            <h3 class="text-xl font-bold text-white">{member.name}</h3>
            <p class="text-slate-400">{member.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>