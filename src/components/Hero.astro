---
const stats = [
  { value: "200K", label: "Clientes felices" },
  { value: "20+", label: "Años de experiencia" },
  { value: "24/7", label: "Atención al cliente" },
];
---

<section class="relative pt-44 pb-20 px-6 overflow-hidden">
  <!-- Fondo de puntos sutil -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 50px 50px;"></div>

  <div class="max-w-full md:max-w-7xl mx-auto grid lg:grid-cols-12 gap-12 items-center relative z-10">
    
    <!-- Columna de Texto -->
    <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
      <span class="inline-flex items-center gap-2 py-2 px-4 rounded-full bg-[#142e2e] text-lime-400 text-xs md:text-sm border border-[#1f4646]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        Crea tu proyecto soñado con nosotros
      </span>
      
      <h1 class="text-4xl md:text-6xl xl:text-7xl font-bold text-[#0a1b1b] leading-tight tracking-tight">
        Experiencia en soluciones de <br class="hidden lg:block"> <span class="text-lime-400">Call Center BPO</span>
      </h1>
      
      <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto lg:mx-0 leading-relaxed">
        Delegar sus operaciones de call center puede revolucionar la forma en que gestiona la atención al cliente, con nuestro equipo de expertos manejándolo todo.
      </p>

      <!-- Estadísticas -->
      <div class="grid grid-cols-3 gap-4 pt-6 border-t border-[#1f4646]">
        {stats.map(stat => (
          <div>
            <div class="text-2xl md:text-4xl font-bold text-[#0a1b1b] tabular-nums">{stat.value}</div>
            <div class="text-slate-500 text-xs md:text-sm mt-1">{stat.label}</div>
          </div>
        ))}
      </div>

      <div class="flex justify-center lg:justify-start pt-4">
        <button class="bg-lime-400 text-black px-8 py-4 rounded-full font-bold text-md hover:bg-lime-300 transition flex items-center gap-3 group">
          Potencia tu atención al cliente
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </button>
      </div>
    </div>

    <!-- Columna de Imágenes -->
    <div class="lg:col-span-5 relative h-[400px] md:h-[650px] w-full flex justify-center items-center">
      
      <!-- Imagen 1: Agente con tablet -->
      <div class="absolute top-0 left-[10%] md:left-0 w-[200px] md:w-[380px] h-[250px] md:h-[480px] rounded-t-full rounded-b-3xl overflow-hidden border-[8px] border-lime-400 shadow-2xl z-10">
        <img src="https://images.unsplash.com/photo-1714079761488-e0c9b9ac4138?q=80&w=1171" alt="Agente" class="w-full h-full object-cover" />
      </div>
      
      <!-- Imagen 2: Teleoperadora sonriendo -->
      <div class="absolute bottom-0 right-[10%] md:right-0 w-[180px] md:w-[320px] h-[220px] md:h-[420px] rounded-t-full rounded-b-3xl overflow-hidden border-[8px] border-lime-400 shadow-2xl z-20">
        <img src="https://images.unsplash.com/photo-1711397818306-863530cd27c2?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Nnx8dmlydHVhbCUyMHNlcnZpY2VzfGVufDB8fDB8fHww" alt="Teleoperadora" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>
