---
const features = [
  { text: "Ahorro significativo de costos" },
  { text: "Atención al cliente 24/7" },
  { text: "Integración e incorporación" },
  { text: "Mejora la reputación de la marca" },
  { text: "Términos de contrato flexibles" },
  { text: "Soporte omnicanal" },
];
---

<section id="elegirnos" class="py-20 px-6 bg-[#0a1b1b]">
  <div class="max-w-6xl mx-auto text-center">
    <!-- Etiqueta -->
    <div class="inline-flex items-center gap-2 py-1 px-4 rounded-full bg-[#142e2e] text-lime-400 text-sm border border-[#1f4646] mb-6">
      Por qué elegirnos
    </div>
    
    <!-- Título -->
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-16">
      Atención al cliente que hace <br class="hidden md:block" /> escalar tu negocio
    </h2>

    <!-- Contenido Principal -->
    <div class="grid md:grid-cols-3 gap-8 items-center">
      
      <!-- Lado Izquierdo (3 puntos) -->
      <div class="flex flex-col gap-6">
        {features.slice(0, 3).map(f => (
          <div class="flex items-center justify-end gap-4 text-white bg-[#142e2e]/30 p-4 rounded-full border border-slate-700/30">
            <span class="font-medium">{f.text}</span>
            <div class="bg-lime-400 p-1 rounded-full text-black">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>
            </div>
          </div>
        ))}
      </div>

      <!-- Imagen Central -->
      <div class="order-first md:order-none flex justify-center mb-8 md:mb-0">
        <div class="w-72 h-[450px] rounded-t-full rounded-b-3xl overflow-hidden border-4 border-lime-400 shadow-2xl">
          <img src="https://plus.unsplash.com/premium_photo-1683141038528-5bd315b70768?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Atención al cliente" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Lado Derecho (3 puntos) -->
      <div class="flex flex-col gap-6">
        {features.slice(3, 6).map(f => (
          <div class="flex items-center justify-start gap-4 text-white bg-[#142e2e]/30 p-4 rounded-full border border-slate-700/30">
            <div class="bg-lime-400 p-1 rounded-full text-black">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="font-medium">{f.text}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>