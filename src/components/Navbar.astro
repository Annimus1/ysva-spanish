---
const logoPlaceholder = "YSVA"; 
---

<nav class="fixed top-5 left-0 right-0 z-50 mx-auto w-[90%] max-w-7xl rounded-full bg-slate-900/80 backdrop-blur-lg border border-slate-700/50 p-4 shadow-2xl">
  <div class="flex items-center justify-between px-4">
    
    <!-- Logo -->
    <div class="text-lime-400 font-bold text-4xl tracking-tight z-50">
      <img src="../../public/Logo.png" alt="Your Company Logo" class="w-16 md:w-24 h-auto" />
    </div>

    <!-- Menú Desktop -->
    <div class="hidden md:flex items-center gap-8 text-slate-200 font-medium">
      <a href="#hero" class="text-white font-bold text-lg">Inicio</a>
      <a href="#elegirnos" class="text-white font-bold text-lg">Por qué elegirnos</a>
      <a href="#comoLoHacemos" class="text-white font-bold text-lg">Cómo lo hacemos</a>
      <a href="#servicios" class="text-white font-bold text-lg">Servicios</a>
      <a href="#testimonios" class="text-white font-bold text-lg">Testimonios</a>
      <a href="#equipo" class="text-white font-bold text-lg">Equipo</a>
    </div>

    <!-- Acciones CTA -->
    <div class="hidden md:flex items-center gap-3">
      <a href="#cta" class="bg-lime-400 text-black px-6 py-2 rounded-full font-bold hover:bg-lime-300 transition text-xl">Contacto</a>
    </div>

    <!-- Botón Hamburguesa (Móvil) -->
    <button id="menu-btn" class="md:hidden text-white z-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  <!-- Menú Mobile (Desplegable) -->
  <div id="mobile-menu" class="hidden absolute top-full mt-2 left-0 w-full bg-slate-900/95 backdrop-blur-lg border border-slate-700/50 rounded-3xl p-6 flex-col gap-4 text-center md:hidden">
    <a href="#hero" class="text-white font-bold text-lg">Inicio</a>
    <a href="#elegirnos" class="text-white font-bold text-lg">Por qué elegirnos</a>
    <a href="#comoLoHacemos" class="text-white font-bold text-lg">Cómo lo hacemos</a>
    <a href="#servicios" class="text-white font-bold text-lg">Servicios</a>
    <a href="#testimonios" class="text-white font-bold text-lg">Testimonios</a>
    <a href="#equipo" class="text-white font-bold text-lg">Equipo</a>
    <a href="#cta" class="bg-lime-400 text-black py-3 rounded-full font-bold">Contacto</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
</script>