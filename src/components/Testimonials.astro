---
const testimonials = [
  {
    name: "Sheldon Jackson",
    role: "Propietario de tienda",
    text: "Hemos trabajado con YSVA por más de dos años, su atención al cliente 24/7 ha sido un cambio radical para nosotros. Manejan nuestras llamadas entrantes con profesionalismo.",
    img: "https://i.pravatar.cc/150?u=1"
  },
  {
    name: "Maria Rodriguez",
    role: "Directora de Operaciones",
    text: "La eficiencia del equipo de soporte es incomparable. Han logrado escalar nuestras operaciones de manera efectiva y sin fricciones.",
    img: "https://i.pravatar.cc/150?u=2"
  },
  {
    name: "Carlos Mendez",
    role: "Gerente de Ventas",
    text: "Excelente trato y una capacidad técnica destacable. Estamos muy satisfechos con los resultados obtenidos hasta la fecha.",
    img: "https://i.pravatar.cc/150?u=3"
  }
];
---

<section id="testimonios" class="py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 py-1 px-4 rounded-full bg-[#142e2e] text-lime-400 text-sm border border-[#1f4646] mb-4">
        Testimonios
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-[#0a1b1b]">Lo que dicen nuestros clientes</h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 rounded-3xl overflow-hidden h-[400px]">
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?q=80&w=800" class="w-full h-full object-cover" alt="Equipo trabajando" />
      </div>

      <div class="lg:col-span-7 flex items-center gap-8">
        
        <!-- Componente con efecto de barrido de luz (Example-2) -->
        <div class="example-2 relative rounded-[2rem] overflow-hidden bg-[#142e2e] flex-1">
          <div class="before-light"></div>
          
          <div class="inner relative z-10 p-8">
            <div id="test-card" class="transition-opacity duration-300">
              <div class="text-lime-400 mb-4 text-xl">★★★★★</div>
              <h3 class="text-white font-bold text-2xl mb-4">Servicio destacado y soporte 24/7</h3>
              <p id="test-text" class="text-slate-400 text-lg mb-8 leading-relaxed italic">"{testimonials[0].text}"</p>
              
              <div class="flex items-center gap-4">
                <img id="test-img" src={testimonials[0].img} class="w-12 h-12 rounded-full border-2 border-lime-400" />
                <div>
                  <div id="test-name" class="text-white font-bold">{testimonials[0].name}</div>
                  <div id="test-role" class="text-slate-500 text-sm">{testimonials[0].role}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar de avatares -->
        <div class="flex flex-col gap-4">
          {testimonials.map((t) => (
            <button class="avatar-btn w-12 h-12 rounded-full overflow-hidden border-2 border-transparent hover:border-lime-400 transition shadow-lg">
              <img src={t.img} class="w-full h-full object-cover" />
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .example-2 {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .example-2 .inner {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 2px;
    background: #142e2e;
    border-radius: 2rem;
  }

  .before-light {
    content: "";
    display: block;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgb(157, 248, 37) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    height: 680px;  
    width: 180px;
    position: absolute;
    animation: rotate 4s linear infinite;
    z-index: 0;
    top: -150px;
    transform-origin: top center;
  }

  @keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  const testimonials = [
    { name: "Sheldon Jackson", role: "Propietario de tienda", text: "Hemos trabajado con YSVA por más de dos años, su atención al cliente 24/7 ha sido un cambio radical para nosotros. Manejan nuestras llamadas entrantes con profesionalismo.", img: "https://i.pravatar.cc/150?u=1" },
    { name: "Maria Rodriguez", role: "Directora de Operaciones", text: "La eficiencia del equipo de soporte es incomparable. Han logrado escalar nuestras operaciones de manera efectiva y sin fricciones.", img: "https://i.pravatar.cc/150?u=2" },
    { name: "Carlos Mendez", role: "Gerente de Ventas", text: "Excelente trato y una capacidad técnica destacable. Estamos muy satisfechos con los resultados obtenidos hasta la fecha.", img: "https://i.pravatar.cc/150?u=3" }
  ];

  const card = document.getElementById('test-card');
  const text = document.getElementById('test-text');
  const name = document.getElementById('test-name');
  const role = document.getElementById('test-role');
  const img = document.getElementById('test-img');
  const buttons = document.querySelectorAll('.avatar-btn');

  buttons.forEach((button, index) => {
    button.addEventListener('click', () => {
      const t = testimonials[index];
      card.style.opacity = '0';
      setTimeout(() => {
        text.innerText = `"${t.text}"`;
        name.innerText = t.name;
        role.innerText = t.role;
        img.src = t.img;
        card.style.opacity = '1';
      }, 300);
    });
  });
</script>